# =============================================================================
# SentinelX Docker 环境配置
# =============================================================================
# 此文件供 Docker Compose 使用

# 应用配置
APP_NAME=SentinelX
DEBUG=true

# 数据库配置 (Docker 内部使用服务名)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sentinelx

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379

# JWT 配置
JWT_SECRET_KEY=sentinelx-docker-dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI 配置 (留空，如需启用请填入 API Key)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=gpt-4
AI_PROVIDER=openai

# 租户默认配额
DEFAULT_MAX_ALERTS=100000
DEFAULT_MAX_USERS=100
DEFAULT_MAX_RULES=500
DEFAULT_MAX_CHANNELS=100
DEFAULT_ALERT_QPS=1000

# 前端配置
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://sentinelx-backend:8000
VITE_APP_TITLE=SentinelX
VITE_APP_VERSION=1.0.0

# PGMQ
PGMQ_ENABLED=true
