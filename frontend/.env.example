# =============================================================================
# SentinelX 前端环境配置示例
# =============================================================================
# 复制此文件为 .env.local 并修改配置
# cp .env.example .env.local
# =============================================================================

# API 地址 (开发环境使用相对路径)
VITE_API_BASE_URL=/api

# 后端代理目标
# 本地开发 (前后端都在本地，不使用 Docker): http://localhost:8000
# Docker 部署 (前端在 Docker 中): http://sentinelx-backend:8000
VITE_API_PROXY_TARGET=http://localhost:8001

# 应用信息
VITE_APP_TITLE=SentinelX
VITE_APP_VERSION=1.0.0

# 是否启用调试模式
VITE_DEBUG=true
