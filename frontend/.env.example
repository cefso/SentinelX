# =============================================================================
# SentinelX 前端环境配置示例
# =============================================================================
# 复制此文件为 .env.local 并修改配置
# cp .env.example .env.local
# =============================================================================

# API 地址 (开发环境使用相对路径)
VITE_API_BASE_URL=/api

# 后端代理目标
# 本地开发 (前后端都在本地，不使用 Docker): http://localhost:8001
# Docker 部署: 由 nginx.conf 代理到 http://backend:8000
VITE_API_PROXY_TARGET=http://localhost:8001

# 应用信息
VITE_APP_TITLE=SentinelX
VITE_APP_VERSION=1.0.0

# 是否启用调试模式
VITE_DEBUG=true

# 日志配置
# 日志级别: debug/info/warn/error
VITE_LOG_LEVEL=info
# 是否启用日志输出
VITE_ENABLE_LOGGING=true
