# ===========================================
# SentinelX 应用配置
# ===========================================

# 应用配置
APP_NAME=SentinelX
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sentinelx
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20

# JWT配置 (请在生产环境修改)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI配置 (可选)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=gpt-4o

# 配额默认配置
DEFAULT_MAX_ALERTS=10000
DEFAULT_MAX_USERS=10
DEFAULT_MAX_RULES=100
DEFAULT_MAX_CHANNELS=20

# PGMQ配置
PGMQ_ENABLED=true
