# =============================================================================
# SentinelX 综合告警平台 - 环境配置示例
# =============================================================================
# 复制此文件为 .env 并修改配置
# cp .env.example .env
# =============================================================================

# ============ 应用配置 ============
APP_NAME=SentinelX
APP_VERSION=1.0.0
DEBUG=true
API_V1_PREFIX=/api/v1

# ============ 后端服务端口 ============
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# ============ 数据库配置 (PostgreSQL) ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sentinelx
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ============ Redis 配置 ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20

# ============ JWT 配置 (生产环境必须修改!) ============
JWT_SECRET_KEY=your-secret-key-change-in-production-abc123xyz
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ AI 配置 (可选) ============
# OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# DASHSCOPE_API_KEY=your-dashscope-api-key
AI_MODEL=gpt-4
AI_PROVIDER=openai

# ============ 租户默认配额 ============
DEFAULT_MAX_ALERTS=10000
DEFAULT_MAX_USERS=10
DEFAULT_MAX_RULES=100
DEFAULT_MAX_CHANNELS=20
DEFAULT_ALERT_QPS=100

# ============ 前端配置 ============
# 前端 API 地址 (开发环境使用相对路径，生产环境使用 Nginx 反向代理)
VITE_API_BASE_URL=/api
VITE_APP_TITLE=SentinelX
VITE_APP_VERSION=1.0.0

# ============ PGMQ 消息队列 (可选) ============
PGMQ_ENABLED=true
